# ============================================================
# Aquapool Environment Variables — copy to .env and fill in
# ============================================================

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://aquapool:password@localhost:5432/aquapool
REDIS_URL=redis://localhost:6379

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=aquapool

# --- Auth Service ---
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Blockchain RPCs ---
ALCHEMY_API_KEY=your_alchemy_key
INFURA_API_KEY=your_infura_key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
BSC_RPC_URL=https://bsc-dataseed1.binance.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
XRP_RPC_URL=wss://xrplcluster.com
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# --- Market Data ---
COINMARKETCAP_API_KEY=your_cmc_key
COINGECKO_API_KEY=your_coingecko_key

# --- MPC / Key Management ---
MPC_PROVIDER_URL=https://your-mpc-provider.com
MPC_API_KEY=your_mpc_key

# --- KYC / Identity ---
ONFIDO_API_KEY=your_onfido_key
SUMSUB_APP_TOKEN=your_sumsub_token
SUMSUB_SECRET_KEY=your_sumsub_secret

# --- AML / Compliance ---
CHAINALYSIS_API_KEY=your_chainalysis_key
COMPLY_ADVANTAGE_API_KEY=your_comply_advantage_key

# --- Broker / TradFi ---
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Notifications ---
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# --- Cross-Chain Bridges ---
LAYERZERO_ENDPOINT=your_layerzero_endpoint
WORMHOLE_RPC_HOST=https://api.wormholescan.io

# --- Service Ports ---
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
WALLET_SERVICE_PORT=3003
EXCHANGE_SERVICE_PORT=3004
MARKET_DATA_SERVICE_PORT=3005
REMITTANCE_SERVICE_PORT=3006
EARN_SERVICE_PORT=3007
COMPLIANCE_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009

# --- Web App (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:3005/ws
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=get-from-cloud.walletconnect.com

# --- Mobile App (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WS_URL=ws://localhost:3005/ws

# --- DEX Aggregators ---
ONEINCH_API_KEY=your_1inch_api_key
JUPITER_API_URL=https://quote-api.jup.ag/v6
